# ============================================
# Michibiki Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ============================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase Service Role Key (server-side only, NEVER prefix with NEXT_PUBLIC_)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Custom domain
# NEXT_PUBLIC_SITE_URL=https://michibiki.tech

# Optional: Google OAuth (configured in Supabase dashboard)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
