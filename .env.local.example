# Supabase Configuration
# 1. Go to https://supabase.com and create a new project
# 2. Go to Settings > API to find these values
# 3. Copy this file as .env.local and fill in the values

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Fish Audio TTS (https://fish.audio)
# Get your API key from the Fish Audio dashboard
FISH_AUDIO_API_KEY=your-fish-audio-api-key
# Optional: Set voice model IDs from https://fish.audio voice library
FISH_AUDIO_VOICE_MALE=
FISH_AUDIO_VOICE_FEMALE=
